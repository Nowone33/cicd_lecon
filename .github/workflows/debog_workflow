name: Workflow cassé
on:
  -  workflow_dispatch
env:
  ma variable: "valeur_test"
  $my_secret = "secret_value"
jobs:
 build_job:
runs-on: ubuntu-18.04
 steps:
      - name: Checkout
        uses: actions/checkout@v3
      - name: Afficher variable
        run: echo "${{ env.ma_variables }}"
      - name: Test commande
        run: |
          echo "Hello World"
          if [ true ] then echo "Vrai" fi
  test-job:
    runs-on: ubuntu-latest
    needs: [build job, final-job]
    steps:
      - name: Test
        run: echo "Test"
